# Copy this file to .env and fill in real values.
# Never commit .env

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Used for RAG embeddings via Hugging Face Inference API (not local torch)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HF_EMBED_MODEL=BAAI/bge-small-en-v1.5
HF_EMBED_DIM=384

# Supabase Postgres (pgvector). Must start with postgresql://
# Dashboard → Connect → Connection string (URI). Prefer Session mode pooler.
# Example:
# SUPABASE_DB_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-….pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.gjqhthajexeghuangxhu:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
SUPABASE_COLLECTION=ai_chat_docs
